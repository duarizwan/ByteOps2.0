# ===========================================
# ByteOps Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000
# Frontend URL used by backend for OAuth2 redirect-back (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:3000

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/byteops?sslmode=require

# --- AI / LLM ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- OAuth2 Tool Integrations ---
# Gmail
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# JIRA
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/auth/jira/callback

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/auth/slack/callback

# Trello
TRELLO_API_KEY=
TRELLO_API_SECRET=
TRELLO_REDIRECT_URI=http://localhost:8000/api/auth/trello/callback

# Dropbox
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:8000/api/auth/dropbox/callback

# Google Calendar
# If you use the same Google Cloud project as Gmail, leave CALENDAR_CLIENT_ID/SECRET blank
# and the backend will automatically fall back to GMAIL_CLIENT_ID/SECRET.
# Only fill these in if you use a separate Google OAuth2 client for Calendar.
CALENDAR_CLIENT_ID=
CALENDAR_CLIENT_SECRET=
CALENDAR_REDIRECT_URI=http://localhost:8000/api/auth/calendar/callback
